# 本地vLLM配置（当API_TYPE=local时使用）
VLLM_HOST=localhost
VLLM_PORT=8000
VLLM_MODEL_PATH=./models/qwen-7b-int4

# NVIDIA API配置（当API_TYPE=nvidia时使用）
NVIDIA_API_KEY=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
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm-5.1

# 硅基流动API配置（当API_TYPE=silicon_flow时使用）
SILICON_FLOW_API_KEY=sk-czzpwrzncqygoqmwdtojcmmsfgwzdnoqgrruarzdcrfjzzgn
SILICON_FLOW_BASE_URL=https://api.siliconflow.cn/v1
